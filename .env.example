# Copy this file to .env and fill in real values before running docker-compose.
# NEVER commit .env with real secrets.

# SQL Server SA password used by the local dev container (docker-compose only).
# Must satisfy SQL Server complexity requirements (mix of upper/lower/digit/symbol).
MSSQL_SA_PASSWORD=ChangeMe_Dev123!

# Full ADO.NET connection string for the local dev db-init and backend containers.
SQL_CONNECTION_STRING_LOCAL=Server=tcp:db,1433;Initial Catalog=bingo_db;User ID=sa;Password=ChangeMe_Dev123!;Encrypt=false;TrustServerCertificate=true;

# Static admin API key used only in local dev / smoke tests.
# Must be a long random string (>= 32 chars). Never reuse production values.
ADMIN_KEY=replace-with-a-long-random-string

# HS256 secret used to sign admin JWTs. Must be >= 32 bytes of random entropy.
JWT_SECRET=replace-with-a-long-random-jwt-secret-at-least-32-chars

# Comma-separated list of admin email addresses for local testing.
ADMIN_EMAILS=admin@example.com
