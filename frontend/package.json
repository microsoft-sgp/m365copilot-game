{
  "name": "m365copilot-bingo-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Vue 3 + Tailwind frontend for the Copilot Chat Bingo game.",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "e2e": "playwright test",
    "e2e:ci": "playwright test --reporter=line",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  }
}
