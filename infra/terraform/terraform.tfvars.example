subscription_id             = "8b14080f-2d4f-4817-8b92-b0d85a6cc993"
resource_group_name         = "rg-m365copilot-game-dev"
resource_group_location     = "koreacentral"
location                    = "koreacentral"
sql_location                = "koreacentral"
communication_data_location = "United States"
environment                 = "dev"
name_prefix                 = "m365copilot-game"
default_campaign_id         = "APR26"

# Replace with real bootstrap admin emails before production use.
admin_emails = [
  "admin@test.com",
]

# Add custom frontend origins here if you use a custom domain. The frontend
# App Service hostname is included automatically.
# allowed_origins = [
#   "https://bingo.example.com",
# ]

# Cookie/session defaults. Production cookies are emitted as Secure and
# SameSite=None so the frontend App Service can call the Function App with
# credentials.
# admin_access_ttl_seconds  = 900
# admin_refresh_ttl_seconds = 604800
# admin_step_up_ttl_seconds = 300

# Functions plan defaults. EP1 is the smallest Elastic Premium SKU. If your
# subscription has no Elastic Premium quota, use a dedicated Premium v3/v4 SKU
# with available quota, such as P0v3.
# function_plan_sku_name             = "EP1"
# function_pre_warmed_instance_count = 1

# Frontend App Service plan SKU. B1 is suitable for dev/test when quota is
# available; use P0v3/P1v3 or higher when Basic VM quota is unavailable.
# frontend_app_service_sku_name = "B1"

# Azure Managed Redis defaults. Balanced_B0 is the smallest managed SKU for
# dev/test; choose a larger Balanced, ComputeOptimized, or FlashOptimized SKU
# for production throughput and resilience requirements.
# redis_sku_name         = "Balanced_B0"
# redis_clustering_policy = "NoCluster"
# redis_eviction_policy   = "AllKeysLRU"

# Cache TTL defaults in seconds.
# cache_ttl_active_campaign_seconds = 60
# cache_ttl_org_domains_seconds     = 300
# cache_ttl_leaderboard_seconds     = 30

# Server-side enforcement of the per-player session token. MUST stay true in
# production. Set to false only as an emergency rollback for the
# player-session-auth capability.
enable_player_token_enforcement = true

# Azure Communication Services resources are globally scoped by Azure. The
# data_location value is data residency, not the regional deployment location;
# change only if your tenancy requires another supported ACS data location.

# Optional: allow a workstation to run sqlcmd migrations directly.
# sql_allowed_ip_ranges = {
#   my_workstation = {
#     start_ip_address = "203.0.113.10"
#     end_ip_address   = "203.0.113.10"
#   }
# }
